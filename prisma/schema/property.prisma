model Property {
  id           Int          @id @default(autoincrement())
  agentId      String
  title        String
  description  String
  imageUrl     String
  location     String
  priceRange   String
  propertyType PropertyType
  isVerified   Boolean      @default(false)
  isAdvertised Boolean      @default(false)
  isBought     Boolean      @default(false)
  generatedAt  DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  agent         Agent          @relation(fields: [agentId], references: [id])
  wishlistItems WishlistItem[]

  Review           Review[]
  bookedProperties BookedProperty[]
  soldProperties   SoldProperty[]
}

model BookedProperty {
  id                   Int      @id @default(autoincrement())
  propertyId           Int
  userId               String
  agentId              String
  proposedAmount       String
  isPropAmountAccepted Boolean  @default(false)
  isSold               Boolean  @default(false)
  bookedAt             DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([propertyId, userId])

  property       Property       @relation(fields: [propertyId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
  agent          Agent          @relation(fields: [agentId], references: [id])
  soldProperties SoldProperty[]
}

model SoldProperty {
  id               Int      @id @default(autoincrement())
  bookedPropertyId Int     @unique
  propertyId       Int
  userId           String
  agentId          String
  amount           String
  soldAt           DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([propertyId, userId])

  bookedProperty BookedProperty @relation(fields: [bookedPropertyId], references: [id])
  property       Property       @relation(fields: [propertyId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
  agent          Agent          @relation(fields: [agentId], references: [id])
}
